HF_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_URL=https://api-inference.huggingface.co/models

OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=gemma:2b

TIMEOUT_MS=12000
GLOBAL_TIMEOUT_MS=14000
LOCAL_TIMEOUT_MS=12000
CLOUD_TIMEOUT_MS=12000
SIMPLE_THRESHOLD=60

LOCAL_MAX_TOKENS=64
LOCAL_TEMPERATURE=0.3
LOCAL_RETRIES=1

CLOUD_MAX_TOKENS=80
CLOUD_TEMPERATURE=0.4
CLOUD_RETRIES=1

ENABLE_GUARDRAILS=true
ENABLE_MEMORY=true
ENABLE_LOGS=true
ENABLE_WARMUP=true
ENABLE_PARALLEL_MODE=false
ENABLE_ADAPTIVE_ROUTING=true
MEMORY_LIMIT=6
HEALTH_TTL_MS=20000
CACHE_TTL_MS=45000
METRICS_WINDOW_SIZE=20

ENABLE_FALLBACK=true
FALLBACK_ON_TIMEOUT=true
FALLBACK_ON_ERROR=true
FALLBACK_ON_INVALID=true

BLOCK_NON_SPANISH=true
MIN_LATIN_RATIO=0.75

DEBUG_MODE=false
LOG_LEVEL=info

WA_SESSION_ID=ollama-whatsapp-bot
# CHROME_PATH=/usr/bin/google-chrome
